# Copy to .env for local dev.

# Bind address + port
HOST=0.0.0.0
PORT=4400

# Prisma:
#   dev (SQLite, no infra) — keep as-is
#   prod (Postgres)        — uncomment the postgresql:// line and run
#                            `npx prisma migrate deploy` once.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://vibeplan:vibeplan@localhost:5432/vibeplan?schema=public"

# CORS — comma-separated list of allowed origins.
# For the desktop macOS app we don't need CORS strictly, but it's set so
# you can hit endpoints from a browser during debugging.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info
