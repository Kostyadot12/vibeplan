# Copy to .env for local dev.

# Bind address + port
HOST=0.0.0.0
PORT=4400

# Prisma:
#   dev (SQLite, no infra) — keep as-is
#   prod (Postgres)        — uncomment the postgresql:// line and run
#                            `npx prisma migrate deploy` once.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://vibeplan:vibeplan@localhost:5432/vibeplan?schema=public"

# CORS — comma-separated list of allowed origins.
# For the desktop macOS app we don't need CORS strictly, but it's set so
# you can hit endpoints from a browser during debugging.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Auth
JWT_SECRET=dev-secret-change-me-in-prod
JWT_TTL=30d

# On first start, this email is auto-added to the whitelist as admin if the
# whitelist is empty. Once at least one admin exists, this is ignored.
BOOTSTRAP_ADMIN_EMAIL=kos2cherdan@gmail.com

# Resend (transactional email). If unset — codes go to server log instead.
# Get a key at https://resend.com (free tier covers 100 emails/day).
# RESEND_API_KEY=re_xxxxxxxxxx
# MAIL_FROM="VibePlan <noreply@your-domain.com>"
