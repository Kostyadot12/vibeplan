// Prisma schema for VibePlan backend.
//
// Dev uses SQLite (file dev.db, zero infra). For prod, swap `provider` to
// "postgresql" and point DATABASE_URL at a Postgres instance — the rest of
// the schema is identical.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id              String   @id @default(cuid())
  title           String
  note            String   @default("")
  startDate       DateTime
  durationMinutes Int      @default(30)
  category        String   @default("work")
  status          String   @default("open")
  sortOrder       Int      @default(0)
  inInbox         Boolean  @default(false)
  // Minutes before startDate to fire a system notification (client-side).
  // null = no reminder.
  reminderMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Phase 3: who created it (nullable while we backfill / for legacy data)
  creatorId String?
  creator   User?   @relation("CreatedTasks", fields: [creatorId], references: [id])

  // Phase 6: where this task lives. NULL = personal (visible only to creator).
  // Otherwise belongs to a space and is visible to all space members.
  spaceId String?
  space   Space?  @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  subtasks    Subtask[]
  assignees   TaskAssignee[]
  attachments Attachment[]
  comments    Comment[]
  tags        TaskTag[]

  @@index([startDate])
  @@index([inInbox])
  @@index([creatorId])
  @@index([spaceId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  role      String   @default("member") // "admin" | "member"
  avatarUrl String?                     // path under /uploads/avatars/
  createdAt DateTime @default(now())

  createdTasks   Task[]         @relation("CreatedTasks")
  assignedTasks  TaskAssignee[]
  ownedSpaces    Space[]        @relation("OwnedSpaces")
  spaceMemberships SpaceMember[]
}

// A "space" is a folder/team — set of tasks visible to its members.
// Owner can rename, recolor, invite, kick, delete.
model Space {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("work")  // matches PlanCategory palette
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation("OwnedSpaces", fields: [ownerId], references: [id])

  members SpaceMember[]
  tasks   Task[]
  pendingInvites PendingSpaceInvite[]

  @@index([ownerId])
}

// Many-to-many: which users belong to which space.
model SpaceMember {
  spaceId  String
  userId   String
  role     String   @default("member")  // "owner" | "member"
  joinedAt DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([spaceId, userId])
  @@index([userId])
}

// Invitation issued for an email that has no User record yet. Resolved into
// a SpaceMember on the user's first login.
model PendingSpaceInvite {
  id        String   @id @default(cuid())
  email     String
  spaceId   String
  role      String   @default("member")
  invitedAt DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([email, spaceId])
  @@index([email])
}

// M:N join table — multiple users can be assigned to one task.
model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model AllowedEmail {
  email     String   @id
  role      String   @default("member") // "admin" | "member"
  invitedAt DateTime @default(now())
  note      String   @default("")
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String                // sha256 of code, never store plaintext
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  consumed  Boolean  @default(false)

  @@index([email])
  @@index([expiresAt])
}

model Subtask {
  id    String  @id @default(cuid())
  title String
  done  Boolean @default(false)
  order Int     @default(0)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  filename     String
  mimeType     String
  sizeBytes    Int
  storagePath  String   // path under /uploads/attachments/<file>
  uploadedAt   DateTime @default(now())
  uploadedById String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// Free-form colored labels — orthogonal to fixed PlanCategory.
// Scoped to a space (or null for personal).
model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("work")
  spaceId   String?              // null = personal/global to creator
  ownerId   String?
  createdAt DateTime @default(now())

  tasks TaskTag[]

  @@unique([spaceId, name])
  @@index([spaceId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId],  references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

// Append-only feed of recent activity for visibility/social proof.
model ActivityEvent {
  id         String   @id @default(cuid())
  spaceId    String?              // null for personal-task events (only the user sees them)
  actorId    String?
  taskId     String?
  kind       String               // "task.created" | "task.updated" | "task.deleted" |
                                  //  "comment.created" | "attachment.added" | "space.member.joined"
  summary    String               // short human-readable line
  createdAt  DateTime @default(now())

  @@index([spaceId, createdAt])
  @@index([actorId])
}
