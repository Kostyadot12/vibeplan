// Prisma schema for VibePlan backend.
//
// Dev uses SQLite (file dev.db, zero infra). For prod, swap `provider` to
// "postgresql" and point DATABASE_URL at a Postgres instance — the rest of
// the schema is identical.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id              String   @id @default(cuid())
  title           String
  note            String   @default("")
  startDate       DateTime
  durationMinutes Int      @default(30)
  category        String   @default("work")
  status          String   @default("open")
  sortOrder       Int      @default(0)
  inInbox         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Phase 3: who created it (nullable while we backfill / for legacy data)
  creatorId String?
  creator   User?   @relation("CreatedTasks", fields: [creatorId], references: [id])

  subtasks Subtask[]

  @@index([startDate])
  @@index([inInbox])
  @@index([creatorId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  role      String   @default("member") // "admin" | "member"
  createdAt DateTime @default(now())

  createdTasks Task[] @relation("CreatedTasks")
}

model AllowedEmail {
  email     String   @id
  role      String   @default("member") // "admin" | "member"
  invitedAt DateTime @default(now())
  note      String   @default("")
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String                // sha256 of code, never store plaintext
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  consumed  Boolean  @default(false)

  @@index([email])
  @@index([expiresAt])
}

model Subtask {
  id    String  @id @default(cuid())
  title String
  done  Boolean @default(false)
  order Int     @default(0)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}
